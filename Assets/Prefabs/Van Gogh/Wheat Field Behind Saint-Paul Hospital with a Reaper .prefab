  m_Script: {fileID: 11500000, guid: 965994f2c96676e4cb5c993fc6354aab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  paintingTitle: 'Wheat Field Behind Saint-Paul Hospital with a Reaper '
  artistName: Vincent van Gogh
  paintingDescription: "Van Gogh painted this walled field from his hospital room.
    For the first few months that he was there, he was not allowed to leave the grounds.\r\n\r\nThe
    reaper labours in the heat of the sun. The wheat, painted with thick gobs of
    yellow, undulates around him. For Van Gogh, wheat was a symbol of the eternal
    cycle of nature and the transience of life. He saw the reaper as 'the image of
    death . . . in this sense that humanity would be the wheat being reaped.'\r\n\r\nHe
    added, however, that this death was 'almost smiling. It's all yellow except for
    a line of violet hills \u2013 a pale, blond yellow. I myself find that funny,
    that I saw it like that through the iron bars of a cell.'"
  paintingImage: {fileID: 2800000, guid: 4fa0d50e95ae39a4a8f5fc33ebfc8a9c, type: 3}
  orientation: 0
  frameThickness: 0.15
  artworkDepth: 0.04
  frameDepth: 0.12
