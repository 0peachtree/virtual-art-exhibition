  m_Script: {fileID: 11500000, guid: 965994f2c96676e4cb5c993fc6354aab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  paintingTitle: Self-Portrait with Grey Felt Hat
  artistName: Vincent van Gogh
  paintingDescription: "Van Gogh painted this self-portrait in the winter of 1887\u201388,
    when he had been in Paris for almost two years. It is clear from the work that
    he had studied the technique of the Pointillists and applied it in his own, original
    way. He placed the short stripes of paint in different directions. Where they
    follow the outline of his head, they form a kind of halo.\r\n\r\nThe painting
    is also one of Van Gogh\u2019s boldest colour experiments in Paris. He placed
    complementary colours alongside one another using long brushstrokes: blue and
    orange in the background, and red and green in the beard and eyes. The colours
    intensify one another. The red pigment has faded, so the purple strokes are now
    blue, which means the contrast with the yellow is less powerful."
  paintingImage: {fileID: 2800000, guid: fb2fde629afafa94ca86748f32f5be32, type: 3}
  orientation: 1
  frameThickness: 0.15
  artworkDepth: 0.04
  frameDepth: 0.12
  artworkMesh: {fileID: 3418459353476150557}
  frameTop: {fileID: 406626238996569644}
  frameBottom: {fileID: 4575771702483235082}
  frameLeft: {fileID: 3818162960553797146}
  frameRight: {fileID: 384559273203728952}
