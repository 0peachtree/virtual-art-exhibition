  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 965994f2c96676e4cb5c993fc6354aab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  paintingTitle: 'Cypresses '
  artistName: Vincent van Gogh
  paintingDescription: "Cypresses was painted in late June 1889, shortly after Van
    Gogh began his yearlong stay at the asylum in Saint-R\xE9my. The subject, which
    he found \"beautiful as regards lines and proportions, like an Egyptian obelisk,\"
    both captivated and challenged the artist: \"It\u2019s the dark patch in a sun-drenched
    landscape, but it\u2019s one of the most interesting dark notes, the most difficult
    to hit off exactly that I can imagine.\" One of two close-up views of the \"very
    tall and massive\" trees in a vertical format (the other is in the Kr\xF6ller-M\xFCller
    Museum, Otterlo), Cypresses was shown in the 1890 Salon des Ind\xE9pendants."
  paintingImage: {fileID: 2800000, guid: 20992c57c84f84b4b985acce5d8ee023, type: 3}
  orientation: 1
  frameThickness: 0.15
  artworkDepth: 0.04
  frameDepth: 0.12
  artworkMesh: {fileID: 5843868784260612422}
  frameTop: {fileID: 999452033863715539}
