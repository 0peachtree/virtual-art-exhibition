  m_Script: {fileID: 11500000, guid: 965994f2c96676e4cb5c993fc6354aab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  paintingTitle: 'Green Wheat Fields, Auvers '
  artistName: Vincent van Gogh
  paintingDescription: "Green Wheat Fields, Auvers was painted during these final
    months in Auvers. In this village just north of Paris, Van Gogh painted the Romanesque
    church, the town hall, and some of the picturesque thatched-roof houses. As he
    did in the countryside surrounding Arles and Saint-R\xE9my, he also painted more
    or less \"pure\" landscapes. This work is indeed singular in that there is no
    legible motif beyond the grassy field, road, and sky; no farmers or horse-driven
    carts; no rural structures. Instead, pure flora is whipped up by the wind. Two-thirds
    of the composition consists of the field in a rich range of greens and blues,
    punctuated by outbursts of yellow flowers. As in the paintings he completed in
    the countryside surrounding Arles and Saint- R\xE9my, here Van Gogh painted a
    \u201Cpure\u201D landscape."
  paintingImage: {fileID: 2800000, guid: b7bc74492a3049541a5bf7d1c7443fb2, type: 3}
  orientation: 0
  frameThickness: 0.15
  artworkDepth: 0.04
  frameDepth: 0.12
