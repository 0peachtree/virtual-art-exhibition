  m_Script: {fileID: 11500000, guid: 965994f2c96676e4cb5c993fc6354aab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  paintingTitle: First Steps, after Millet
  artistName: Vincent van Gogh
  paintingDescription: "In fall and winter 1889\u201390, while a voluntary patient
    at the asylum in Saint-R\xE9my, Van Gogh painted twenty-one copies after Millet,
    an artist he greatly admired. He considered his copies \"translations\" akin
    to a musician's interpretation of a composer's work. He let the black-and-white
    images\u2014whether prints, reproductions, or, as here, a photograph that his
    brother, Theo, had sent\u2014pose \"as a subject,\" then he would \"improvise
    color on it.\" For this work of January 1890, Van Gogh squared-up a photograph
    of Millet's First Steps and transferred it to the canvas."
  paintingImage: {fileID: 2800000, guid: 144db6697c52bbc4dbdd99cc16108e4c, type: 3}
  orientation: 0
  frameThickness: 0.15
  artworkDepth: 0.04
  frameDepth: 0.12
