  m_Script: {fileID: 11500000, guid: 965994f2c96676e4cb5c993fc6354aab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  paintingTitle: 'Vineyards at Auvers '
  artistName: Vincent van Gogh
  paintingDescription: "This canvas focuses on the twisted forms of grapevines depicted
    with Vincent van Gogh\u2019s characteristic, heavily loaded brushstroke. Red
    poppies animate the composition, as do the red roofs in the distance. In May
    1890, after spending two years in the south of France, Van Gogh moved to the
    village of Auvers, just to the north of Paris. He spent two prolific months there,
    producing about 70 paintings before his death."
  paintingImage: {fileID: 2800000, guid: fc3ca038f181a2b4eb7a151a44ce6452, type: 3}
  orientation: 0
