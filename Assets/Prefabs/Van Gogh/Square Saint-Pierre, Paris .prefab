  m_Script: {fileID: 11500000, guid: 965994f2c96676e4cb5c993fc6354aab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  paintingTitle: 'Square Saint-Pierre, Paris '
  artistName: Vincent van Gogh
  paintingDescription: "in 1853, Vincent van Gogh painted \u201CSquare Saint-Pierre,
    Paris\u201D shortly after he moved to Paris in 1886 to develop more formal training
    as an artist. Prior to his arrival, he had not seen Impressionist paintings,
    nor was he aware of the contemporary radical changes in color and design that
    Post-Impressionist painters of his generation were introducing, including Paul
    Gauguin and George Seurat. However, van Gogh learned quickly during his time
    abroad. In \u201CSquare Saint-Pierre, Paris\" he uses pointillist techniques,
    likely inspired by Seurat, more fully here than anywhere else and to an exhilarating
    effect. The foliage and pavement seem to shimmer, while the illusion of reflected
    light invades the shadowed areas of the composition. In addition, van Gogh has
    painted the sky with flecks of blue and white paint, radiating up and out of
    the painting, an expressive invention that is unique to him. "
  paintingImage: {fileID: 2800000, guid: 5f8ac085db4cb0547896700473abb4de, type: 3}
  orientation: 0
  frameThickness: 0.15
  artworkDepth: 0.04
  frameDepth: 0.12
  artworkMesh: {fileID: 5366170702371122429}
  frameTop: {fileID: 1331310010437523364}
  frameBottom: {fileID: 7024534817142280832}
