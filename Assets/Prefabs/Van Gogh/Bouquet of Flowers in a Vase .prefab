  m_Script: {fileID: 11500000, guid: 965994f2c96676e4cb5c993fc6354aab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  paintingTitle: 'Bouquet of Flowers in a Vase '
  artistName: Vincent van Gogh
  paintingDescription: "This still life is not mentioned in Van Gogh\u2019s letters
    and has puzzled scholars as to its place in his artistic production. The subject
    enjoys a certain rapport with the mixed bouquets of summer flowers he made in
    Paris; the quasi-abstract floral wallpaper design in the Berceuse of Arles (1996.435),
    and the white porcelain vase in the Irises of Saint-R\xE9my (58.187). However,
    the palette and style of this painting, especially its distinctive blues and
    ochers and graphic, brick-shape hatchings, link it firmly with the landscapes
    made just prior to his death in Auvers on July 29, 1890."
  paintingImage: {fileID: 2800000, guid: 8c3c474fbfd6c414bb22c15c4c5d101a, type: 3}
  orientation: 1
  frameThickness: 0.15
  artworkDepth: 0.04
  frameDepth: 0.12
  artworkMesh: {fileID: 3164121579239649024}
  frameTop: {fileID: 1768691834005898632}
  frameBottom: {fileID: 5999041345447104957}
  frameLeft: {fileID: 825584038498933542}
  frameRight: {fileID: 1464785076333960220}
